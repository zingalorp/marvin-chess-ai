!marvin_wrapper.sh

# ============================
# Documentation & Config (Include)
# ============================
!.gitignore
!README.md
!requirements.txt

# ============================
# Exclude (Implicit with * at top)
# ============================
# - checkpoints/ (large model files)
# - data/ and data_v2/ (large training data)
# - runs/ (tensorboard logs)
# - __pycache__/ (Python cache)
# - venv/ (virtual environments)
# - old_scripts/ (deprecated code)
# - goodversions/ (backup code)
# - notebooks/ (experimental notebooks)
# - *.pt files (except those in inference/)
# - *.parquet files (training data)



