# ============================

# Model and training
!model.py
!train.py
!dataset.py

# Data preprocessing
!process_pgn.py
!profile_data.py
!calculate_retention_rates.py
!visualize_profile.py

# Evaluation
!compare_ACPL.py

# ============================
# Inference (Include)
# ============================
!inference/
!inference/*.py

# ============================
# Lichess-bot integration (Include)
# ============================
